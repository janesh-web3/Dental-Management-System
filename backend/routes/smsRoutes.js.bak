const express = require('express');
const router = express.Router();
const { 
    sendSingleSMS, 
    sendBulkSMS, 
    getTemplates,
    createTemplate,
    updateTemplate,
    deleteTemplate,
    getSMSHistory,
    processScheduledSMS,
    smsStatusCallback,
    checkSMSCredit,
    getDetailedSMSCredit,
    getSMSReport
} = require('../controller/smsController');
const authMiddleware = require('../middleware/authMiddleware');
const doctorAuthMiddleware = require('../middleware/doctorAuthMiddleware');
const adminAuthMiddleware = require('../middleware/adminAuthMiddleware');

// SMS sending endpoints - protected by authentication
router.post('/single', authMiddleware, sendSingleSMS);
router.post('/bulk', authMiddleware, sendBulkSMS);

// Template management endpoints - protected by authentication
router.get('/templates', authMiddleware, getTemplates);
router.post('/templates', authMiddleware, createTemplate);
router.put('/templates/:templateId', authMiddleware, updateTemplate);
router.delete('/templates/:templateId', authMiddleware, deleteTemplate);

// SMS history endpoints - protected by authentication
router.get('/history', authMiddleware, getSMSHistory);

// Credit management endpoints - protected by authentication
router.get('/credit', authMiddleware, checkSMSCredit);
router.get('/credit/detailed', adminAuthMiddleware, getDetailedSMSCredit);

// Report endpoints - admin only
router.get('/report', adminAuthMiddleware, getSMSReport);

// Scheduled SMS processing - admin only
router.post('/process-scheduled', adminAuthMiddleware, processScheduledSMS);

// Status callback endpoint - public endpoint (for future use with provider webhooks)
router.post('/status-callback', smsStatusCallback);

module.exports = router;