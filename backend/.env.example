# Aakash SMS Configuration
AAKASH_SMS_AUTH_TOKEN=your_aakash_sms_auth_token
AAKASH_SMS_CREDIT_ALERT_THRESHOLD=100

# SMS Scheduler API Key (for securing the scheduler endpoint)
SMS_SCHEDULER_API_KEY=your_secure_api_key

# API URL for SMS Scheduler
API_URL=http://localhost:8080/api

# Legacy Twilio Configuration (Not used for SMS sending, kept for reference)
# TWILIO_ACCOUNT_SID=your_twilio_account_sid
# TWILIO_AUTH_TOKEN=your_twilio_auth_token
# TWILIO_PHONE_NUMBER=your_twilio_phone_number
# TWILIO_STATUS_CALLBACK_URL=https://your-domain.com/api/sms/status-callback
# TWILIO_INBOUND_URL=https://your-domain.com/api/sms/inbound
